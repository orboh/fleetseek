{
  "name": "robonet",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "api:dev": "npm run dev --workspace=@robonet/api",
    "db:migrate": "npm run db:migrate --workspace=@robonet/api",
    "db:seed": "npm run db:seed --workspace=@robonet/api"
  },
  "packageManager": "npm@10.8.2",
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
