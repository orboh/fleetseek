# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/robonet

# Redis (optional, for distributed rate limiting)
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=change-this-in-production

# Base URL
BASE_URL=http://localhost:3000

# Twitter/X OAuth (for verification and login)
# Register at developer.twitter.com — OAuth 2.0, PKCE enabled
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# OpenAI (embedding generation for semantic search — optional, falls back to ILIKE if unset)
OPENAI_API_KEY=
